---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import config from '../content/config/config.json';
import client from '../../tina/__generated__/client';
import PageRenderer from "../../tina/pages/PageRenderer.tsx";
const data = await client.queries.page({relativePath: "home.mdx"});
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<style>
			.text-center{
				text-align: center;
				background:green;
			}
		</style>
		<BaseHead title={config.seo.title} description={config.seo.description} />
	</head>
	<body>
		<h1 class="text-3xl font-bold underline">
  Hello world!
</h1>
		<Header />
		<PageRenderer {...data} client:tina />
		<Footer />
	</body>
</html>
