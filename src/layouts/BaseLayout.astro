---
import "../styles/global.css";
import NewNav from "../components/navigation/NewNav.astro";
import Footer from "../components/ui/Footer.astro";
import { Font } from 'astro:assets';
import config from "../content/config/config.json";

import { client } from '../../tina/__generated__/client';

const response = await client.queries.config({ relativePath: 'config.json' });
// Double check this path! Is it global.nav or global.navigation?
const navItems = response.data.config.nav;
console.log("NAV ITEMS:", navItems); 
const {
  title = config.seo.title || "My Site",
  description = "Default description",
  image = "/images/og.jpg",
  url = "https://example.com"
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />


    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Your Business Name",
        "url": url,
        "description": description
      })}
      </script>
        <Font cssVariable="--font-poppins" preload />
        <Font cssVariable="--font-merriweather" preload />
  </head>

  <body class="text-gray-800 bg-white hello">

  <NewNav navData={navItems} /> 


   

     <div>
  <slot />
</div>



    <Footer />

  </body>
</html>