---
// src/components/navigation/nav/Dropdown.astro
interface Props {
  label: string;
  alignment: string;
  subMenu: {
    label: string;
    link: string;
  }[];
}

const { label, subMenu, alignment } = Astro.props;

// Align the dropdown panel
const menuAlignClass = alignment === "justify-end" ? "right-0" : "left-0";

// Align the underline direction
const underlineClass = alignment === "justify-end" ? "right-0" : "left-0";
---

<div class="relative group h-full flex items-center">
  <button class="relative py-2 font-medium flex items-center gap-1 transition-colors hover:text-blue-600">
    {label}
    
    <!-- Rotating Arrow -->
    <svg 
      xmlns="http://w3.org" 
      class="h-4 w-4 transition-transform duration-300 group-hover:rotate-180" 
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>

    <!-- Underline Animation -->
    <span class={`absolute bottom-0 h-0.5 bg-blue-600 transition-all duration-300 w-0 group-hover:w-full ${underlineClass}`}></span>
  </button>

  <!-- Dropdown Menu Panel -->
  <div class={`
    absolute top-full z-50 w-48 bg-white shadow-xl rounded-b-lg border border-gray-100 overflow-hidden
    invisible opacity-0 translate-y-2
    group-hover:visible group-hover:opacity-100 group-hover:translate-y-0
    transition-all duration-300 ease-out
    ${menuAlignClass}
  `}>
    <ul class="flex flex-col py-2">
      {subMenu?.map((sub) => (
        <li>
          <a 
            href={sub.link} 
            class="block px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors"
          >
            {sub.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>
